APP_NAME="Olufunke Football Academy"
APP_ENV=production
APP_KEY=base64:HDkdKI5Z4nNQaqVm2pKO4L7Vm8eNb7bDPv6XF/VWBCI=
APP_DEBUG=false
APP_URL=https://olufunkefootballacademy.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=single
LOG_LEVEL=error

# ── Database — Railway MySQL service (set these in Railway Variables tab) ───────
# When you add a MySQL service in Railway, use these reference variables:
DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQL_HOST}}
DB_PORT=${{MySQL.MYSQL_PORT}}
DB_DATABASE=${{MySQL.MYSQL_DATABASE}}
DB_USERNAME=${{MySQL.MYSQL_USER}}
DB_PASSWORD=${{MySQL.MYSQL_PASSWORD}}

# ── Session ────────────────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.olufunkefootballacademy.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_COOKIE=olufunkefa_session

# ── Cache / Queue ──────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ── Mail ───────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@olufunkefootballacademy.com
MAIL_FROM_NAME="Olufunke Football Academy"
