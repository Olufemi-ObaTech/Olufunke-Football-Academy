APP_NAME="Olufunke Football Academy"
APP_ENV=production
APP_KEY=base64:HDkdKI5Z4nNQaqVm2pKO4L7Vm8eNb7bDPv6XF/VWBCI=
APP_DEBUG=false
APP_URL=https://olufunkefootballacademy.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=single
LOG_LEVEL=error

# ─── cPanel MySQL — fill in your cPanel database details ──────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_cpanel_username_olufunke
DB_USERNAME=your_cpanel_username_olufunke
DB_PASSWORD=YourDatabasePassword

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.olufunkefootballacademy.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_COOKIE=olufunkefa_session

# ─── Cache / Queue ────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ─── Mail (use your WhoGoHost email) ─────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.olufunkefootballacademy.com
MAIL_PORT=465
MAIL_USERNAME=noreply@olufunkefootballacademy.com
