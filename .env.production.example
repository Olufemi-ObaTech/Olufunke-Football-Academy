# ============================================================
# PRODUCTION .env for Laravel deployment (Railway / Render / cPanel)
# Copy this as .env on your server — DO NOT commit .env to git
# ============================================================

APP_NAME="OFA Academy"
APP_ENV=production
APP_KEY=          # Run: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-laravel-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database (from Railway/Render/cPanel) ──────────────────
DB_CONNECTION=mysql
DB_HOST=your-db-host
DB_PORT=3306
DB_DATABASE=olufunke_db
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password

# ── Sessions ───────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_COOKIE=ofaacademy_session

# ── Cache & Queue ──────────────────────────────────────────
CACHE_STORE=database
QUEUE_CONNECTION=database

# ── Mail (use Mailgun, SendGrid, or Resend in production) ──
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=your-mailgun-username
MAIL_PASSWORD=your-mailgun-password
MAIL_FROM_ADDRESS="noreply@ofaacademy.com"
MAIL_FROM_NAME="OFA Academy"

# ── Filesystem ─────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Supabase (optional — if you want Laravel to also use Supabase) ──
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
