# ============================================================
# OFA Academy — Environment Variables
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — NEVER commit real keys.
# ============================================================

# ── Supabase (get from: Supabase Dashboard → Project → Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=https://fpqkewuoymyodveqbfjc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# ── Site URL ────────────────────────────────────────────────────────────
# Local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production (set in Netlify dashboard / GitHub secret):
# NEXT_PUBLIC_SITE_URL=https://olufunkefootballacademy.com

# ── Notes ────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_* keys are safe to use in the browser (public/anon key only).
# SUPABASE_SERVICE_ROLE_KEY is SECRET — only used in Netlify Functions (server-side).
# It must NEVER appear in client-side code or be committed to git.
